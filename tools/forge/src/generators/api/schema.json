{
  "$schema": "https://json-schema.org/schema",
  "$id": "ForgeApi",
  "title": "Forge API Generator",
  "type": "object",
  "properties": {
    "framework": {
      "type": "string",
      "enum": ["hono", "python"],
      "default": "hono",
      "description": "Backend framework — Hono (TypeScript) or Python (FastAPI)"
    },
    "database": {
      "type": "string",
      "enum": ["sqlite", "postgres"],
      "default": "sqlite",
      "description": "Database engine"
    },
    "optionalFeatures": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional features for the Hono framework: ai, agents, payments, email, realtime, cron, vector, observability"
    },
    "targetDir": {
      "type": "string",
      "description": "Absolute path to the generated project root. Required when running from forge CLI."
    }
  },
  "required": []
}
