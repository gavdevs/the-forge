# Backend API base URL. The apiClient (./src/lib/apiClient.ts) reads
# this at build time.
#
# FastAPI (python framework):   VITE_API_URL=http://localhost:8000
# Hono + tRPC (hono framework): tRPC talks to /trpc on port 3000; no VITE_API_URL needed.
<% if (apiFramework === 'python') { %>VITE_API_URL=http://localhost:8000
<% } %>
